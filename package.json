{
  "name": "maida-prototype",
  "description": "Maida - Daily Focus Psychopomp",
  "author": "Bright Raven",
  "private": true,
  "version": "0.0.7",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "scan": "node ../tools/scanner.js",
    "electron:dev": "concurrently --kill-others \"npm run dev\" \"wait-on tcp:5173 -i 100 && cross-env NODE_ENV=development electron .\"",
    "start": "npm run electron:dev",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:prod": "cross-env VITE_DISABLE_DEBUG=true npm run dist:win",
    "dist:debug": "cross-env VITE_DISABLE_DEBUG=false npm run dist:win",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "howlongtobeat": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "agentation": "^2.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.3"
  }
}