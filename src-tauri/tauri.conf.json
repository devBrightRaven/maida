{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maida",
  "version": "0.3.0",
  "identifier": "com.brightraven.maida",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Maida",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://api.igdb.com https://id.twitch.tv; img-src 'self' https://steamcdn-a.akamaihd.net https://cdn.akamai.steamstatic.com https://images.igdb.com data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyNjAwNzYxNjg4MThENTkKUldSWmpZRm9ZUWRnUW9uTzhlcjd0aEpnMWhMcEh3dWF0Vml1YUIvcXNJODZ2SDR1RVpUV0VWTU4K",
      "endpoints": [
        "https://github.com/devBrightRaven/maida/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  }
}
