{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:allow-restart"
  ]
}
